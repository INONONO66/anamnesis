{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/anamnesis-hook.sh session-start",
            "timeout": 10,
            "statusMessage": "Loading anamnesis context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/anamnesis-hook.sh user-prompt",
            "timeout": 5,
            "statusMessage": "Recalling relevant memory"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/anamnesis-hook.sh stop",
            "timeout": 5,
            "statusMessage": "Capturing turn"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/anamnesis-hook.sh pre-compact",
            "timeout": 10,
            "statusMessage": "Flushing capture"
          }
        ]
      }
    ]
  }
}
